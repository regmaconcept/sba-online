# ─────────────────────────────────────────────────────────────────────────────
# SBA School Manager — Server Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit the .env file to Git.
# ─────────────────────────────────────────────────────────────────────────────

# Google Sheets — Spreadsheet ID
# Found in the Google Sheets URL:
# https://docs.google.com/spreadsheets/d/THIS_PART_HERE/edit
SPREADSHEET_ID=your_spreadsheet_id_here

# Google Service Account credentials
# From the JSON key file you download from Google Cloud Console
GOOGLE_CLIENT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nyour_private_key_here\n-----END RSA PRIVATE KEY-----\n"

# JWT secret — use any long random string (min 32 chars)
JWT_SECRET=change-this-to-a-long-random-secret-string-minimum-32-chars

# Port for the server (default 4000)
PORT=4000

# Frontend URL for CORS (your React app URL)
# In development: http://localhost:3000
# In production: https://your-app.vercel.app
CLIENT_URL=http://localhost:3000
